//@version=6
strategy("Bear Bounce Dual Confirm V5", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_type=strategy.commission.percent, commission_value=0.26, initial_capital=2000)

// === V5 DualConfirm OPTIMIZED ===
// Backtest 60d resultaat (285 coins, 0.26% fee, 1x$2000):
//   V5: +$4,711 P&L, WR 91.7%, PF 107.81, DD 1.8% (12 trades)
//   V4: +$4,553 P&L, WR 83.3%, PF 78.29, DD 1.9% (12 trades)
//
// V5 wijziging t.o.v. V4:
//   + RSI Recovery Exit: als RSI >= 45-47 EN >= 2 bars in trade -> exit
//   - Pakt bounce-winst voordat RSI weer wegzakt
//   - Converteert ACA trade van -$15 verlies naar +$143 winst
//   - Robuust van target 42-47, cliff edge bij 48
//   - Aanbevolen: target=45 (productie), target=47 (maximaal)

// === DONCHIAN INPUTS ===
donchian_period  = input.int(20, "Donchian Period", minval=5, maxval=50, group="Donchian")
rsi_donchian_max = input.int(40, "RSI Max (Donchian entry)", minval=20, maxval=50, group="Donchian")

// === BOLLINGER INPUTS ===
bb_period        = input.int(20, "BB Period", minval=5, maxval=50, group="Bollinger")
bb_dev           = input.float(2.0, "BB Deviation", minval=1.0, maxval=4.0, step=0.1, group="Bollinger")
rsi_buy_bb       = input.int(40, "RSI Buy (BB oversold)", minval=15, maxval=50, group="Bollinger")
rsi_sell_bb      = input.int(70, "RSI Sell (BB overbought)", minval=55, maxval=85, group="Bollinger")

// === SHARED INPUTS ===
rsi_period       = input.int(14, "RSI Period", minval=5, maxval=30, group="Shared")
atr_period       = input.int(14, "ATR Period", minval=5, maxval=30, group="Shared")
atr_stop_mult    = input.float(2.0, "ATR Stop Multiplier", minval=0.5, maxval=5.0, step=0.1, group="Shared")
cooldown_bars    = input.int(4, "Cooldown Bars", minval=0, maxval=20, group="Shared")
cooldown_stop    = input.int(8, "Cooldown After Stop", minval=0, maxval=20, group="Shared")
max_stop_loss    = input.float(15.0, "Max Stop Loss %", minval=5.0, maxval=30.0, step=1.0, group="Shared")

// === V2 OPTIMALISATIE INPUTS ===
use_vol_spike    = input.bool(true, "Volume Spike Filter", group="V2 Optimalisatie", tooltip="Entry alleen bij volume >2x gemiddelde")
vol_spike_mult   = input.float(2.0, "Vol Spike Multiplier", minval=1.0, maxval=5.0, step=0.1, group="V2 Optimalisatie")
vol_avg_period   = input.int(20, "Vol Average Period", minval=5, maxval=50, group="V2 Optimalisatie")
use_breakeven    = input.bool(true, "Break-Even Stop", group="V2 Optimalisatie", tooltip="Na +3% winst, stop naar entry + fee buffer")
be_trigger_pct   = input.float(3.0, "BE Trigger %", minval=1.0, maxval=10.0, step=0.5, group="V2 Optimalisatie")
vol_min_pct      = input.float(0.5, "Min Volume (% of avg)", minval=0.0, maxval=1.0, step=0.1, group="V2 Optimalisatie")

// === V4 OPTIMALISATIE INPUTS ===
time_max_bars    = input.int(10, "Time Max Bars", minval=0, maxval=50, group="V4 Optimalisatie", tooltip="Force exit na 10 bars (40h)")
use_vol_confirm  = input.bool(true, "Volume Bar Confirm", group="V4 Optimalisatie", tooltip="Entry volume > vorige bar volume")
vol_confirm_mult = input.float(1.0, "Vol Confirm Multiplier", minval=0.5, maxval=3.0, step=0.1, group="V4 Optimalisatie")

// === V5 RSI RECOVERY EXIT ===
use_rsi_recovery = input.bool(true, "RSI Recovery Exit", group="V5 RSI Recovery", tooltip="Exit wanneer RSI herstelt naar neutraal niveau. Robuust 42-47, cliff bij 48.")
rsi_recovery_target = input.int(45, "RSI Recovery Target", minval=35, maxval=55, group="V5 RSI Recovery", tooltip="Aanbevolen: 45 (veilig) of 47 (maximaal). NIET hoger dan 47!")
rsi_recovery_min_bars = input.int(2, "Min Bars voor RSI Exit", minval=1, maxval=10, group="V5 RSI Recovery", tooltip="Minimaal 2 bars in trade voordat RSI exit actief wordt")

// === INDICATORS ===
// Donchian Channel
highest_high = ta.highest(high, donchian_period)
lowest_low   = ta.lowest(low, donchian_period)
mid_channel  = (highest_high + lowest_low) / 2
prev_lowest  = ta.lowest(low[1], donchian_period)

// Bollinger Bands
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_period, bb_dev)

// RSI & ATR
rsi_val = ta.rsi(close, rsi_period)
atr_val = ta.atr(atr_period)

// Volume
vol_avg = ta.sma(volume, vol_avg_period)
vol_ratio = vol_avg > 0 ? volume / vol_avg : 0.0

// === TRACKING VARIABLES ===
var float stop_price = 0.0
var float highest_price = 0.0
var float entry_price_track = 0.0
var int last_exit_bar = -999
var bool last_exit_was_stop = false
var bool just_bought = false
var bool just_sold_target = false
var bool just_sold_stop = false
var bool just_sold_rsi = false
var bool just_sold_hard = false
var bool just_sold_time = false
var bool just_sold_recovery = false
var int entry_bar_index = 0

// Reset flags elke bar
just_bought := false
just_sold_target := false
just_sold_stop := false
just_sold_rsi := false
just_sold_hard := false
just_sold_time := false
just_sold_recovery := false

// Smart cooldown
cd_needed = last_exit_was_stop ? cooldown_stop : cooldown_bars
in_cooldown = (bar_index - last_exit_bar) < cd_needed

// === ENTRY: DUAL CONFIRM + V2/V4 FILTERS ===
donchian_signal = low <= prev_lowest and rsi_val < rsi_donchian_max and close > close[1]
bb_signal = close <= bb_lower and rsi_val < rsi_buy_bb and close > close[1]

// Volume filters
vol_ok = vol_avg > 0 ? volume >= vol_avg * vol_min_pct : true
vol_spike_ok = use_vol_spike ? (vol_avg > 0 ? vol_ratio >= vol_spike_mult : true) : true
vol_confirm_ok = use_vol_confirm ? (volume[1] > 0 ? volume / volume[1] >= vol_confirm_mult : true) : true

// Dual confirm: BEIDE signalen + alle volume filters
long_entry = donchian_signal and bb_signal and vol_ok and vol_spike_ok and vol_confirm_ok
can_enter = long_entry and not in_cooldown and strategy.position_size == 0

// === ENTRY ===
if can_enter
    strategy.entry("Long", strategy.long)
    stop_price := close - atr_val * atr_stop_mult
    hard_stop_level = close * (1 - max_stop_loss / 100)
    if stop_price < hard_stop_level
        stop_price := hard_stop_level
    highest_price := close
    entry_price_track := close
    just_bought := true
    entry_bar_index := bar_index

// === EXIT ===
if strategy.position_size > 0
    bars_in_trade = bar_index - entry_bar_index

    // Update trailing stop
    if close > highest_price
        highest_price := close
    new_stop = highest_price - atr_val * atr_stop_mult
    hard_stop_level = entry_price_track * (1 - max_stop_loss / 100)
    if new_stop < hard_stop_level
        new_stop := hard_stop_level

    // Break-even stop
    if use_breakeven
        profit_pct = (close - entry_price_track) / entry_price_track * 100
        if profit_pct >= be_trigger_pct
            be_level = entry_price_track * 1.006
            if new_stop < be_level
                new_stop := be_level

    if new_stop > stop_price
        stop_price := new_stop

    // Exit 1: Hard max loss (15%)
    if close < entry_price_track * (1 - max_stop_loss / 100)
        strategy.close("Long", comment="HARD STOP")
        last_exit_bar := bar_index
        last_exit_was_stop := true
        just_sold_hard := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

    // Exit 2: Time max (10 bars = 40h)
    else if time_max_bars > 0 and bars_in_trade >= time_max_bars
        strategy.close("Long", comment="TIME MAX")
        last_exit_bar := bar_index
        last_exit_was_stop := close < entry_price_track
        just_sold_time := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

    // Exit 3: V5 RSI Recovery Exit (NIEUW)
    else if use_rsi_recovery and bars_in_trade >= rsi_recovery_min_bars and rsi_val >= rsi_recovery_target
        strategy.close("Long", comment="RSI RECOVERY")
        last_exit_bar := bar_index
        last_exit_was_stop := false
        just_sold_recovery := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

    // Exit 4: DC mid channel target
    else if close >= mid_channel
        strategy.close("Long", comment="DC TARGET")
        last_exit_bar := bar_index
        last_exit_was_stop := false
        just_sold_target := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

    // Exit 5: BB mid target
    else if close >= bb_mid
        strategy.close("Long", comment="BB TARGET")
        last_exit_bar := bar_index
        last_exit_was_stop := false
        just_sold_target := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

    // Exit 6: RSI overbought
    else if rsi_val > rsi_sell_bb
        strategy.close("Long", comment="RSI EXIT")
        last_exit_bar := bar_index
        last_exit_was_stop := false
        just_sold_rsi := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

    // Exit 7: Trailing stop
    else if close < stop_price
        strategy.close("Long", comment="TRAIL STOP")
        last_exit_bar := bar_index
        last_exit_was_stop := true
        just_sold_stop := true
        highest_price := 0.0
        stop_price := 0.0
        entry_price_track := 0.0

// === PLOTS ===
// Donchian Channel
p_dc_upper = plot(highest_high, "DC Upper", color=color.new(color.red, 70), linewidth=1)
p_dc_mid   = plot(mid_channel, "DC Mid (target)", color=color.new(color.orange, 40), linewidth=2, style=plot.style_stepline)
p_dc_lower = plot(lowest_low, "DC Lower (buy zone)", color=color.new(color.green, 40), linewidth=2, style=plot.style_stepline)
fill(p_dc_upper, p_dc_lower, color=color.new(color.gray, 95), title="DC Band")

// Bollinger Bands
plot(bb_upper, "BB Upper", color=color.new(color.blue, 70), linewidth=1)
plot(bb_mid, "BB Mid", color=color.new(color.blue, 50), linewidth=1, style=plot.style_circles)
plot(bb_lower, "BB Lower", color=color.new(color.blue, 70), linewidth=1)

// Trailing stop
plot(strategy.position_size > 0 ? stop_price : na, "Trailing Stop", color=color.new(color.fuchsia, 0), style=plot.style_linebr, linewidth=2)

// Hard stop loss level
plot(strategy.position_size > 0 ? entry_price_track * (1 - max_stop_loss / 100) : na, "Hard Stop (15%)", color=color.new(color.red, 30), style=plot.style_linebr, linewidth=1)

// Break-even level
be_active = strategy.position_size > 0 and use_breakeven and ((close - entry_price_track) / entry_price_track * 100 >= be_trigger_pct)
plot(be_active ? entry_price_track * 1.006 : na, "Break-Even", color=color.new(color.lime, 30), style=plot.style_linebr, linewidth=1)

// V5: RSI Recovery target level
rsi_rec_active = strategy.position_size > 0 and use_rsi_recovery and (bar_index - entry_bar_index) >= rsi_recovery_min_bars
// Toon RSI recovery target als horizontale lijn in RSI pane (via plotshape)

// === BUY / SELL MARKERS ===
plotshape(just_bought, "BUY", shape.triangleup, location.belowbar, color.lime, size=size.normal, text="BUY", textcolor=color.lime)
plotshape(just_sold_target, "TARGET", shape.triangledown, location.abovebar, color.orange, size=size.normal, text="TARGET", textcolor=color.orange)
plotshape(just_sold_rsi, "RSI EXIT", shape.triangledown, location.abovebar, color.yellow, size=size.normal, text="RSI", textcolor=color.yellow)
plotshape(just_sold_stop, "TRAIL STOP", shape.xcross, location.abovebar, color.red, size=size.normal, text="STOP", textcolor=color.red)
plotshape(just_sold_hard, "HARD STOP", shape.xcross, location.abovebar, color.fuchsia, size=size.normal, text="HARD\nSTOP", textcolor=color.fuchsia)
plotshape(just_sold_time, "TIME MAX", shape.triangledown, location.abovebar, color.gray, size=size.normal, text="TIME", textcolor=color.gray)
plotshape(just_sold_recovery, "RSI RECOVERY", shape.diamond, location.abovebar, color.aqua, size=size.normal, text="RSI\nREC", textcolor=color.aqua)

// === BACKGROUND ===
buy_zone = close <= lowest_low * 1.01 and close <= bb_lower and rsi_val < rsi_buy_bb
bgcolor(buy_zone ? color.new(color.green, 88) : na, title="Buy Zone")
bgcolor(strategy.position_size > 0 ? color.new(color.blue, 95) : na, title="In Position")
bgcolor(vol_spike_ok and buy_zone ? color.new(color.teal, 85) : na, title="Vol Spike + Buy Zone")

// === INFO TABLE ===
var table info = table.new(position.top_right, 2, 16, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Dual Confirm V5", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, "DC+BB+VOL+RSIrec", text_color=color.aqua, text_size=size.small)

    table.cell(info, 0, 1, "RSI(14)", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 1, str.tostring(rsi_val, "#.0"), text_color=rsi_val < 40 ? color.lime : rsi_val > 70 ? color.red : rsi_val >= rsi_recovery_target ? color.aqua : color.white, text_size=size.tiny)

    table.cell(info, 0, 2, "RSI Rec Target", text_color=color.gray, text_size=size.tiny)
    rsi_rec_text = use_rsi_recovery ? str.tostring(rsi_recovery_target) + (rsi_rec_active ? " ACTIVE" : " wait") : "OFF"
    table.cell(info, 1, 2, rsi_rec_text, text_color=rsi_rec_active and rsi_val >= rsi_recovery_target ? color.aqua : use_rsi_recovery ? color.gray : color.red, text_size=size.tiny)

    table.cell(info, 0, 3, "DC Lower", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 3, str.tostring(lowest_low, "#.####"), text_color=close <= lowest_low * 1.01 ? color.lime : color.white, text_size=size.tiny)

    table.cell(info, 0, 4, "DC Mid", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 4, str.tostring(mid_channel, "#.####"), text_color=close >= mid_channel ? color.orange : color.white, text_size=size.tiny)

    table.cell(info, 0, 5, "BB Lower", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 5, str.tostring(bb_lower, "#.####"), text_color=close <= bb_lower ? color.lime : color.white, text_size=size.tiny)

    table.cell(info, 0, 6, "BB Mid", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 6, str.tostring(bb_mid, "#.####"), text_color=close >= bb_mid ? color.orange : color.white, text_size=size.tiny)

    table.cell(info, 0, 7, "Vol Ratio", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 7, str.tostring(vol_ratio, "#.1") + "x", text_color=vol_ratio >= vol_spike_mult ? color.lime : vol_ratio >= 1.0 ? color.white : color.red, text_size=size.tiny)

    table.cell(info, 0, 8, "ATR", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 8, str.tostring(atr_val, "#.######"), text_color=color.white, text_size=size.tiny)

    table.cell(info, 0, 9, "Trail Stop", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 9, strategy.position_size > 0 ? str.tostring(stop_price, "#.####") : "---", text_color=color.fuchsia, text_size=size.tiny)

    table.cell(info, 0, 10, "Hard Stop", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 10, strategy.position_size > 0 ? str.tostring(entry_price_track * (1 - max_stop_loss / 100), "#.####") : "---", text_color=color.red, text_size=size.tiny)

    table.cell(info, 0, 11, "Break-Even", text_color=color.gray, text_size=size.tiny)
    be_text = strategy.position_size > 0 ? (be_active ? str.tostring(entry_price_track * 1.006, "#.####") + " ACTIVE" : "Waiting") : "---"
    table.cell(info, 1, 11, be_text, text_color=be_active ? color.lime : color.gray, text_size=size.tiny)

    table.cell(info, 0, 12, "Bars in Trade", text_color=color.gray, text_size=size.tiny)
    bars_held = strategy.position_size > 0 ? bar_index - entry_bar_index : 0
    table.cell(info, 1, 12, strategy.position_size > 0 ? str.tostring(bars_held) + "/" + str.tostring(time_max_bars) : "---", text_color=bars_held >= time_max_bars - 2 ? color.orange : color.white, text_size=size.tiny)

    table.cell(info, 0, 13, "Unrealized", text_color=color.gray, text_size=size.tiny)
    unr_pnl = strategy.position_size > 0 ? (close - strategy.position_avg_price) / strategy.position_avg_price * 100 : 0.0
    table.cell(info, 1, 13, strategy.position_size > 0 ? str.tostring(unr_pnl, "+#.0") + "%" : "---", text_color=unr_pnl > 0 ? color.lime : unr_pnl < 0 ? color.red : color.gray, text_size=size.tiny)

    table.cell(info, 0, 14, "Position", text_color=color.gray, text_size=size.tiny)
    pos_text = strategy.position_size > 0 ? "LONG" : in_cooldown ? "COOLDOWN" : "FLAT"
    pos_col = strategy.position_size > 0 ? color.lime : in_cooldown ? color.yellow : color.gray
    table.cell(info, 1, 14, pos_text, text_color=pos_col, text_size=size.tiny)

    table.cell(info, 0, 15, "Signal", text_color=color.gray, text_size=size.tiny)
    sig_text = can_enter ? ">>> BUY <<<" : strategy.position_size > 0 ? "HOLD" : donchian_signal and bb_signal ? (vol_spike_ok and vol_confirm_ok ? "READY!" : "NO VOL") : donchian_signal ? "DC OK" : bb_signal ? "BB OK" : "WAIT"
    sig_col = can_enter ? color.lime : strategy.position_size > 0 ? color.yellow : donchian_signal and bb_signal and vol_spike_ok and vol_confirm_ok ? color.aqua : donchian_signal or bb_signal ? color.aqua : color.gray
    table.cell(info, 1, 15, sig_text, text_color=sig_col, text_size=size.tiny)

// === ALERTS ===
if can_enter
    alert("V5 BUY " + syminfo.ticker + " @ " + str.tostring(close) + " | RSI=" + str.tostring(rsi_val, "#.0") + " | Vol=" + str.tostring(vol_ratio, "#.1") + "x", alert.freq_once_per_bar)

if just_sold_recovery
    alert("V5 RSI RECOVERY " + syminfo.ticker + " @ " + str.tostring(close) + " | RSI=" + str.tostring(rsi_val, "#.0"), alert.freq_once_per_bar)

if just_sold_target
    alert("V5 TARGET " + syminfo.ticker + " @ " + str.tostring(close), alert.freq_once_per_bar)

if just_sold_time
    alert("V5 TIME MAX " + syminfo.ticker + " @ " + str.tostring(close) + " | bars=" + str.tostring(bar_index - entry_bar_index), alert.freq_once_per_bar)

if just_sold_stop
    alert("V5 TRAIL STOP " + syminfo.ticker + " @ " + str.tostring(close), alert.freq_once_per_bar)

if just_sold_hard
    alert("V5 HARD STOP " + syminfo.ticker + " | Max loss bereikt", alert.freq_once_per_bar)
