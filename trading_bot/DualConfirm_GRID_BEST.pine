// This Pine Script™ is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// DualConfirm Bounce — GRID_BEST (tp_sl) validated config
// Validated via: WF 5/5, Slippage GO (162bps BE), Rolling 100% stable, Leakage CLEAN

//@version=6
strategy("DualConfirm GRID_BEST [tp_sl]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=2000, commission_type=strategy.commission.percent, commission_value=0.26, pyramiding=0)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════

// Indicator periods
i_dc_period    = input.int(20,   "Donchian Period",      minval=5,  maxval=50)
i_bb_period    = input.int(20,   "Bollinger Period",     minval=5,  maxval=50)
i_bb_dev       = input.float(2.0,"Bollinger StdDev",     minval=0.5,maxval=4.0, step=0.1)
i_rsi_period   = input.int(14,   "RSI Period",           minval=5,  maxval=30)
i_vol_period   = input.int(20,   "Volume Avg Period",    minval=5,  maxval=50)

// Entry filters
i_rsi_max      = input.int(45,   "RSI Max (entry)",      minval=20, maxval=60)
i_vol_spike    = input.float(2.5,"Vol Spike Multiplier", minval=1.0,maxval=5.0, step=0.1)
i_vol_confirm  = input.bool(true,"Vol Confirm (cur>prev)")
i_vol_min_pct  = input.float(0.5,"Vol Min % of Avg",    minval=0.0,maxval=1.0, step=0.1)

// Exit parameters (tp_sl mode)
i_tp_pct       = input.float(12.0,"Take Profit %",      minval=1.0,maxval=30.0, step=0.5)
i_sl_pct       = input.float(10.0,"Stop Loss %",         minval=1.0,maxval=30.0, step=0.5)
i_time_max     = input.int(15,    "Time Max (bars)",     minval=1,  maxval=50)

// Visual
i_show_dc      = input.bool(true, "Show Donchian Low",   group="Visual")
i_show_bb      = input.bool(true, "Show BB Lower",       group="Visual")

// ══════════════════════════════════════════════════════════════
// INDICATORS
// ══════════════════════════════════════════════════════════════

// RSI
rsi_val = ta.rsi(close, i_rsi_period)

// Donchian Channel — previous bar's low channel
//   dc_prev_low = lowest low of the PREVIOUS 20 bars (shift 1)
dc_prev_low = ta.lowest(low[1], i_dc_period)
dc_prev_high = ta.highest(high[1], i_dc_period)

// Bollinger Bands — current bar
bb_mid   = ta.sma(close, i_bb_period)
bb_dev   = ta.stdev(close, i_bb_period) * i_bb_dev
bb_upper = bb_mid + bb_dev
bb_lower = bb_mid - bb_dev

// Volume average (SMA of volume, last N bars)
vol_avg  = ta.sma(volume, i_vol_period)

// ══════════════════════════════════════════════════════════════
// ENTRY CONDITIONS (ALL must be true)
// ══════════════════════════════════════════════════════════════

// 1. Minimum volume filter
vol_min_ok = na(vol_avg) ? true : (volume >= vol_avg * i_vol_min_pct)

// 2. Donchian bounce: low touches previous DC lower + RSI oversold + close bouncing
dc_signal = (low <= dc_prev_low) and (rsi_val < i_rsi_max) and (close > close[1])

// 3. Bollinger bounce: close touches BB lower + RSI oversold + close bouncing
bb_signal = (close <= bb_lower) and (rsi_val < i_rsi_max) and (close > close[1])

// 4. Volume spike: current volume >= avg * multiplier
vol_spike_ok = na(vol_avg) ? false : (volume >= vol_avg * i_vol_spike)

// 5. Volume confirm: current volume >= previous volume
vol_confirm_ok = i_vol_confirm ? (volume >= volume[1]) : true

// Combined entry
entry_signal = vol_min_ok and dc_signal and bb_signal and vol_spike_ok and vol_confirm_ok

// ══════════════════════════════════════════════════════════════
// POSITION TRACKING (for time_max exit)
// ══════════════════════════════════════════════════════════════

var int bars_in_trade = 0
var float entry_price_tracked = na

if strategy.position_size > 0
    bars_in_trade := bars_in_trade + 1
else
    bars_in_trade := 0
    entry_price_tracked := na

// ══════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ══════════════════════════════════════════════════════════════

// ENTRY: only when flat
if entry_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    entry_price_tracked := close
    bars_in_trade := 0

// EXIT: tp_sl mode
//   Priority: SL first, then TP, then TIME_MAX (matches backtest logic)
if strategy.position_size > 0 and not na(entry_price_tracked)
    sl_price = entry_price_tracked * (1 - i_sl_pct / 100)
    tp_price = entry_price_tracked * (1 + i_tp_pct / 100)

    // Fixed Stop Loss
    if low <= sl_price
        strategy.close("Long", comment="FIXED STOP")
    // Profit Target
    else if high >= tp_price
        strategy.close("Long", comment="PROFIT TARGET")
    // Time Max
    else if bars_in_trade >= i_time_max
        strategy.close("Long", comment="TIME MAX")

// ══════════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════════

// Donchian lower (previous bar's)
plot(i_show_dc ? dc_prev_low : na, "DC Prev Low", color=color.new(color.blue, 60), linewidth=1)

// BB lower band
plot(i_show_bb ? bb_lower : na, "BB Lower", color=color.new(color.purple, 60), linewidth=1)

// Entry markers
plotshape(entry_signal and strategy.position_size == 0, "Entry Signal", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small)

// Background: in trade
bgcolor(strategy.position_size > 0 ? color.new(color.green, 92) : na)

// RSI reference line (for info panel)
// plot(rsi_val, "RSI", display=display.data_window)

// ══════════════════════════════════════════════════════════════
// INFO TABLE
// ══════════════════════════════════════════════════════════════

var table info = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(info, 0, 0, "DualConfirm GRID_BEST", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, "tp_sl mode",             text_color=color.gray,  text_size=size.small)
    table.cell(info, 0, 1, "TP / SL",                text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 1, str.tostring(i_tp_pct) + "% / " + str.tostring(i_sl_pct) + "%", text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 0, 2, "TimeMax",                text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 2, str.tostring(i_time_max) + " bars", text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 0, 3, "RSI <",                  text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 3, str.tostring(i_rsi_max),  text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 0, 4, "VolSpike",               text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 4, str.tostring(i_vol_spike) + "x", text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 0, 5, "DC Period",              text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 5, str.tostring(i_dc_period),text_color=color.gray,  text_size=size.tiny)
    table.cell(info, 0, 6, "BB Period",              text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 6, str.tostring(i_bb_period) + " / " + str.tostring(i_bb_dev) + "sd", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 0, 7, "RSI Period",             text_color=color.white, text_size=size.tiny)
    table.cell(info, 1, 7, str.tostring(i_rsi_period),text_color=color.gray, text_size=size.tiny)
