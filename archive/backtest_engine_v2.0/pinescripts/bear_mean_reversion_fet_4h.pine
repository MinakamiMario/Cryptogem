//@version=5
strategy("Bear Mean Reversion (FET 4H) - BEST ALPHA", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_type=strategy.commission.percent, commission_value=0.1, initial_capital=1000)

// === INPUTS ===
bb_period       = input.int(20, "BB Period")
bb_dev          = input.float(2.0, "BB Deviation")
rsi_period      = input.int(14, "RSI Period")
rsi_buy         = input.int(30, "RSI Buy (oversold)")
rsi_sell        = input.int(70, "RSI Sell (overbought)")
atr_period      = input.int(14, "ATR Period")
atr_stop_mult   = input.float(2.0, "ATR Stop Multiplier")

// === INDICATORS ===
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_period, bb_dev)
rsi_val = ta.rsi(close, rsi_period)
atr_val = ta.atr(atr_period)

// === TRACKING VARIABLES ===
var float stop_price = 0.0
var float highest_price = 0.0

// === ENTRY CONDITIONS ===
// Koop: prijs raakt lower BB + RSI oversold + prijs begint te stijgen (bounce)
price_at_lower_bb = close <= bb_lower
rsi_oversold = rsi_val < rsi_buy
price_bouncing = close > close[1]

long_entry = price_at_lower_bb and rsi_oversold and price_bouncing

// === ENTRY ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    stop_price := close - atr_val * atr_stop_mult
    highest_price := close

// === EXIT CONDITIONS ===
if strategy.position_size > 0
    // Update trailing stop
    if close > highest_price
        highest_price := close
    new_stop = highest_price - atr_val * atr_stop_mult
    if new_stop > stop_price
        stop_price := new_stop

    // Exit 1: Prijs bereikt mid BB (mean reversion target)
    if close >= bb_mid
        strategy.close("Long", comment="Mid BB Target")

    // Exit 2: RSI overbought
    else if rsi_val > rsi_sell
        strategy.close("Long", comment="RSI Overbought")

    // Exit 3: Trailing stop
    else if close < stop_price
        strategy.close("Long", comment="Trailing Stop")

// === PLOTS ===
plot(bb_upper, "BB Upper", color=color.new(color.red, 60), linewidth=1)
plot(bb_mid, "BB Mid", color=color.new(color.orange, 40), linewidth=2)
plot(bb_lower, "BB Lower", color=color.new(color.green, 60), linewidth=1)

// Fill between BB bands
fill_upper = plot(bb_upper, display=display.none)
fill_lower = plot(bb_lower, display=display.none)
fill(fill_upper, fill_lower, color=color.new(color.gray, 92), title="BB Band")

// Trailing stop (only when in position)
plot(strategy.position_size > 0 ? stop_price : na, "Trailing Stop", color=color.new(color.fuchsia, 0), style=plot.style_linebr, linewidth=2)

// Entry/exit markers
plotshape(long_entry and strategy.position_size == 0, "Buy Signal", shape.triangleup, location.belowbar, color.lime, size=size.small)

// Background: highlight oversold zones
bgcolor(rsi_val < rsi_buy and close <= bb_lower ? color.new(color.green, 90) : na, title="Buy Zone")
bgcolor(rsi_val > rsi_sell ? color.new(color.red, 92) : na, title="Overbought Zone")

// === INFO TABLE ===
var table info = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(info, 0, 0, "Bear Mean Reversion", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, "FET/USDT 4H", text_color=color.lime, text_size=size.small)
    table.cell(info, 0, 1, "RSI", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 1, str.tostring(rsi_val, "#.0"), text_color=rsi_val < rsi_buy ? color.lime : rsi_val > rsi_sell ? color.red : color.white, text_size=size.tiny)
    table.cell(info, 0, 2, "BB Lower", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 2, str.tostring(bb_lower, "#.####"), text_color=close <= bb_lower ? color.lime : color.white, text_size=size.tiny)
    table.cell(info, 0, 3, "BB Mid", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 3, str.tostring(bb_mid, "#.####"), text_color=close >= bb_mid ? color.orange : color.white, text_size=size.tiny)
    table.cell(info, 0, 4, "ATR", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 4, str.tostring(atr_val, "#.####"), text_color=color.white, text_size=size.tiny)
    table.cell(info, 0, 5, "Stop", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 5, strategy.position_size > 0 ? str.tostring(stop_price, "#.####") : "---", text_color=color.fuchsia, text_size=size.tiny)
    table.cell(info, 0, 6, "Position", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 6, strategy.position_size > 0 ? "IN TRADE" : "FLAT", text_color=strategy.position_size > 0 ? color.yellow : color.gray, text_size=size.tiny)
    table.cell(info, 0, 7, "Signal", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 7, long_entry and strategy.position_size == 0 ? ">>> BUY <<<" : "WAIT", text_color=long_entry and strategy.position_size == 0 ? color.lime : color.gray, text_size=size.tiny)

// === ALERTS ===
alertcondition(long_entry and strategy.position_size == 0, title="Bear MR: BUY", message="BEAR MEAN REVERSION: BUY FET\nPrijs bij lower BB + RSI oversold + bounce\nZet trailing stop op: {{close}} - ATR*2")
alertcondition(strategy.position_size > 0 and close >= bb_mid, title="Bear MR: TARGET", message="BEAR MEAN REVERSION: SELL FET\nMid BB target bereikt op {{close}}")
alertcondition(strategy.position_size > 0 and rsi_val > rsi_sell, title="Bear MR: RSI EXIT", message="BEAR MEAN REVERSION: SELL FET\nRSI overbought op {{close}}")
alertcondition(strategy.position_size > 0 and close < stop_price, title="Bear MR: STOP", message="BEAR MEAN REVERSION: SELL FET\nTrailing stop geraakt op {{close}}")
